      <div style="font-size:11px; color:#8b949e;">Direct from NSE India · No API Key</div>
    </div>""", unsafe_allow_html=True)

    st.sidebar.markdown("---")

    # Watchlist manager
    st.sidebar.markdown("**Your Watchlist**")
    if "watchlist" not in st.session_state:
        st.session_state.watchlist = DEFAULT_WATCHLIST.copy()

    # Add stock
    add_stock = st.sidebar.selectbox(
        "Add stock to watchlist",
        ["-- Select --"] + [s for s in POPULAR_STOCKS if s not in st.session_state.watchlist],
        label_visibility="collapsed",
    )
    if add_stock != "-- Select --":
        st.session_state.watchlist.append(add_stock)
        st.rerun()

    # Custom symbol input
    custom = st.sidebar.text_input("Or type any NSE symbol", placeholder="e.g. ZOMATO").strip().upper()
    if custom and custom not in st.session_state.watchlist:
        if st.sidebar.button(f"Add {custom}"):
            st.session_state.watchlist.append(custom)
            st.rerun()

    # Remove stocks
    if st.session_state.watchlist:
        remove = st.sidebar.multiselect("Remove from watchlist", st.session_state.watchlist)
        if remove:
            st.session_state.watchlist = [s for s in st.session_state.watchlist if s not in remove]
            st.rerun()

    st.sidebar.markdown("---")

    # Auto-refresh toggle
    auto_refresh = st.sidebar.toggle("Auto-refresh (30s)", value=False)
    if auto_refresh:
        refresh_every = st.sidebar.slider("Refresh interval (seconds)", 15, 120, 30)

    st.sidebar.markdown("---")
    st.sidebar.markdown("""
    <div style="font-size:11px; color:#8b949e; line-height:1.8;">
    📡 Data: NSE India public API<br>
    🔑 API Key required: None<br>
    💰 Cost: Free<br>
    ⚡ Latency: ~1-2 seconds<br>
    🕐 Market hours: 9:15–15:30 IST
    </div>""", unsafe_allow_html=True)

    # ── Header ────────────────────────────────────────────────────────────────
    col_h1, col_h2, col_h3, col_h4 = st.columns([3, 1, 1, 1])

    with col_h1:
        st.markdown("## 📈 NSE Live Market")

    # Market status
    market = fetch_market_status(session)
    with col_h2:
        badge = "status-live" if market["open"] else "status-closed"
        st.markdown(f"""
        <div style="padding-top:14px;">
          <span class="{badge}">{'🟢 MARKET OPEN' if market['open'] else '🔴 MARKET CLOSED'}</span>
        </div>""", unsafe_allow_html=True)

    # India VIX
    vix = fetch_india_vix(session)
    vix_color = "#f85149" if vix > 22 else "#e3b341" if vix > 17 else "#3fb950"
    with col_h3:
        st.markdown(f"""
        <div style="padding-top:8px; text-align:center;">
          <div style="font-size:11px; color:#8b949e;">INDIA VIX</div>
          <div style="font-size:22px; font-weight:700; color:{vix_color};">{vix:.1f}</div>
        </div>""", unsafe_allow_html=True)

    with col_h4:
        now_ist = datetime.now(pytz.timezone("Asia/Kolkata")).strftime("%d %b %Y %H:%M:%S IST")
        st.markdown(f"""
        <div style="padding-top:14px; font-size:11px; color:#8b949e; text-align:right;">
          {now_ist}
        </div>""", unsafe_allow_html=True)

    st.markdown("---")

    # ── Fetch All Quotes ──────────────────────────────────────────────────────
    watchlist = st.session_state.watchlist
    if not watchlist:
        st.info("Add stocks to your watchlist using the sidebar.")
        return

    with st.spinner(f"Fetching live quotes for {len(watchlist)} stocks..."):
        quotes = []
        progress = st.progress(0)
        for i, sym in enumerate(watchlist):
            q = fetch_quote(sym, session)
            quotes.append(q)
            progress.progress((i + 1) / len(watchlist))
            time.sleep(0.3)   # be respectful to NSE — small delay between calls
        progress.empty()

    # ── Summary Strip ─────────────────────────────────────────────────────────
    ok_quotes   = [q for q in quotes if q.get("ok")]
    gainers_cnt = sum(1 for q in ok_quotes if q["change_pct"] > 0)
    losers_cnt  = sum(1 for q in ok_quotes if q["change_pct"] < 0)
    flat_cnt    = len(ok_quotes) - gainers_cnt - losers_cnt

    s1, s2, s3, s4 = st.columns(4)
    with s1:
        st.markdown(f"""<div style="background:#161b22;border:1px solid #30363d;border-radius:8px;padding:12px 16px;">
          <div class="label">Stocks Tracked</div>
          <div style="font-size:22px;font-weight:700;color:#e6edf3;">{len(ok_quotes)}</div>
        </div>""", unsafe_allow_html=True)
    with s2:
        st.markdown(f"""<div style="background:#161b22;border:1px solid #3fb950;border-radius:8px;padding:12px 16px;">
          <div class="label">Advancing</div>
          <div style="font-size:22px;font-weight:700;color:#3fb950;">▲ {gainers_cnt}</div>
        </div>""", unsafe_allow_html=True)
    with s3:
        st.markdown(f"""<div style="background:#161b22;border:1px solid #f85149;border-radius:8px;padding:12px 16px;">
          <div class="label">Declining</div>
          <div style="font-size:22px;font-weight:700;color:#f85149;">▼ {losers_cnt}</div>
        </div>""", unsafe_allow_html=True)
    with s4:
        st.markdown(f"""<div style="background:#161b22;border:1px solid #e3b341;border-radius:8px;padding:12px 16px;">
          <div class="label">Unchanged</div>
          <div style="font-size:22px;font-weight:700;color:#e3b341;">— {flat_cnt}</div>
        </div>""", unsafe_allow_html=True)

    st.markdown("<br>", unsafe_allow_html=True)

    # ── Quote Cards Grid (3 columns) ──────────────────────────────────────────
    cols_per_row = 3
    for i in range(0, len(quotes), cols_per_row):
        row_quotes = quotes[i : i + cols_per_row]
        cols = st.columns(cols_per_row)
        for col, q in zip(cols, row_quotes):
            with col:
                render_quote_card(q)

    # ── Live Table View ───────────────────────────────────────────────────────
    st.markdown("---")
    st.markdown("### 📊 Quick Table View")
    if ok_quotes:
        df = pd.DataFrame([{
            "Symbol":    q["symbol"],
            "LTP (₹)":  q["ltp"],
            "Change":   q["change"],
            "Chg %":    q["change_pct"],
            "Open":     q["open"],
            "High":     q["high"],
            "Low":      q["low"],
            "VWAP":     q["vwap"],
            "52W High": q["week52_high"],
            "52W Low":  q["week52_low"],
        } for q in ok_quotes])

        def color_change(val):
            if isinstance(val, float):
                if val > 0:
                    return "color: #3fb950"
                elif val < 0:
                    return "color: #f85149"
            return "color: #e3b341"

        styled = df.style\
            .applymap(color_change, subset=["Change", "Chg %"])\
            .format({
                "LTP (₹)":  "₹{:,.2f}",
                "Change":   "{:+.2f}",
                "Chg %":    "{:+.2f}%",
                "Open":     "₹{:,.2f}",
                "High":     "₹{:,.2f}",
                "Low":      "₹{:,.2f}",
                "VWAP":     "₹{:,.2f}",
                "52W High": "₹{:,.2f}",
                "52W Low":  "₹{:,.2f}",
            })
        st.dataframe(styled, use_container_width=True, hide_index=True)

    # ── Auto Refresh ──────────────────────────────────────────────────────────
    if auto_refresh:
        st.markdown(f"""
        <div style="text-align:center; font-size:12px; color:#8b949e; margin-top:16px;">
          ⏱ Auto-refreshing every {refresh_every} seconds...
        </div>""", unsafe_allow_html=True)
        time.sleep(refresh_every)
        st.rerun()

    # ── Footer ────────────────────────────────────────────────────────────────
    st.markdown("---")
    st.markdown("""
    <div style="text-align:center; color:#8b949e; font-size:11px; padding:4px 0;">
      Data sourced directly from NSE India public API · No broker account or API key required ·
      Refresh page or enable auto-refresh for latest quotes ·
      <strong style="color:#f85149;">Not investment advice.</strong>
    </div>""", unsafe_allow_html=True)


