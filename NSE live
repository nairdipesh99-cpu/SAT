# NSE API FUNCTIONS
# ══════════════════════════════════════════════════════════════════════════════

def fetch_quote(symbol: str, session: requests.Session) -> dict:
    """
    Fetch full live quote for a single NSE equity symbol.
    Returns price info, OHLC, 52W high/low, circuit limits.
    """
    url = f"https://www.nseindia.com/api/quote-equity?symbol={symbol.upper()}"
    try:
        resp = session.get(url, timeout=10)

        # Cookie expired — refresh and retry once
        if resp.status_code in (401, 403, 429):
            refresh_session(session)
            resp = session.get(url, timeout=10)

        if resp.status_code == 200:
            data = resp.json()
            pi   = data.get("priceInfo", {})
            wd   = data.get("industryInfo", {})
            info = data.get("info", {})

            ltp        = pi.get("lastPrice", 0)
            prev_close = pi.get("previousClose", 0)
            change     = pi.get("change", ltp - prev_close)
            change_pct = pi.get("pChange", 0)

            return {
                "symbol":      symbol.upper(),
                "company":     info.get("companyName", symbol),
                "series":      info.get("series", ["EQ"])[0] if info.get("series") else "EQ",
                "ltp":         ltp,
                "open":        pi.get("open", 0),
                "high":        pi.get("intraDayHighLow", {}).get("max", 0),
                "low":         pi.get("intraDayHighLow", {}).get("min", 0),
                "prev_close":  prev_close,
                "change":      round(change, 2),
                "change_pct":  round(change_pct, 2),
                "week52_high": pi.get("weekHighLow", {}).get("max", 0),
                "week52_low":  pi.get("weekHighLow", {}).get("min", 0),
                "vwap":        pi.get("vwap", 0),
                "lower_circuit": pi.get("lowerCP", ""),
                "upper_circuit": pi.get("upperCP", ""),
                "industry":    wd.get("industry", ""),
                "sector":      wd.get("sector", ""),
                "timestamp":   datetime.now(pytz.timezone("Asia/Kolkata")).strftime("%H:%M:%S IST"),
                "ok":          True,
            }
        else:
            return {"symbol": symbol, "ok": False, "error": f"HTTP {resp.status_code}"}

    except requests.exceptions.Timeout:
        return {"symbol": symbol, "ok": False, "error": "Request timed out"}
    except Exception as e:
        return {"symbol": symbol, "ok": False, "error": str(e)}


def fetch_market_status(session: requests.Session) -> dict:
    """Check if NSE market is currently open."""
    try:
        resp = session.get(
            "https://www.nseindia.com/api/marketStatus",
            timeout=8,
        )
        if resp.status_code == 200:
            data = resp.json()
            markets = data.get("marketState", [])
            for m in markets:
                if "Capital" in m.get("market", ""):
                    return {
                        "status":  m.get("marketStatus", "Unknown"),
                        "message": m.get("tradeDate", ""),
                        "open":    m.get("marketStatus", "").lower() == "open",
                    }
    except Exception:
        pass

    # Fallback — check by IST time
    now = datetime.now(pytz.timezone("Asia/Kolkata"))
    is_weekday = now.weekday() < 5
    is_hours   = (9 * 60 + 15) <= (now.hour * 60 + now.minute) <= (15 * 60 + 30)
    is_open    = is_weekday and is_hours
    return {
        "status":  "Open" if is_open else "Closed",
        "message": now.strftime("%d %b %Y"),
        "open":    is_open,
    }


def fetch_india_vix(session: requests.Session) -> float:
    """Fetch live India VIX value."""
    try:
        resp = session.get(
            "https://www.nseindia.com/api/allIndices",
            timeout=8,
        )
        if resp.status_code == 200:
            data = resp.json().get("data", [])
            for item in data:
                if "INDIA VIX" in item.get("index", "").upper():
                    return float(item.get("last", 15.0))
    except Exception:
        pass
    return 15.4


def fetch_gainers_losers(session: requests.Session) -> dict:
    """Fetch top gainers and losers from Nifty 50."""
    try:
        resp = session.get(
            "https://www.nseindia.com/api/live-analysis-variations?index=gainers",
            timeout=8,
        )
        if resp.status_code == 200:
            raw = resp.json()
            gainers = raw.get("NIFTY", {}).get("data", [])[:5]
            losers  = sorted(
                gainers, key=lambda x: x.get("pChange", 0)
            )[:5]
            return {"gainers": gainers, "losers": losers}
    except Exception:
        pass
    return {"gainers": [], "losers": []}


