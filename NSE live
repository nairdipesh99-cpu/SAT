@st.cache_resource
def get_nse_session() -> requests.Session:
    """
    Create a persistent NSE session with cookies.
    NSE requires a browser-like session with cookies set from the homepage
    before accepting API requests — this mimics that flow.
    """
    session = requests.Session()
    session.headers.update({
        "User-Agent":      "Mozilla/5.0 (Windows NT 10.0; Win64; x64) "
                           "AppleWebKit/537.36 (KHTML, like Gecko) "
                           "Chrome/120.0.0.0 Safari/537.36",
        "Accept":          "application/json, text/plain, */*",
        "Accept-Language": "en-US,en;q=0.9",
        "Accept-Encoding": "gzip, deflate, br",
        "Referer":         "https://www.nseindia.com/",
        "Origin":          "https://www.nseindia.com",
        "Connection":      "keep-alive",
    })
    try:
        # Hit homepage first to get session cookies
        session.get("https://www.nseindia.com", timeout=10)
        # Then hit the market data page to get API cookies
        session.get("https://www.nseindia.com/market-data/live-equity-market", timeout=8)
    except Exception:
        pass
    return session


def refresh_session(session: requests.Session) -> None:
    """Re-hit NSE homepage to refresh cookies when they expire."""
    try:
        session.get("https://www.nseindia.com", timeout=10)
        session.get("https://www.nseindia.com/market-data/live-equity-market", timeout=8)
    except Exception:
        pass


